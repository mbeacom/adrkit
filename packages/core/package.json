{
  "name": "@adrkit/core",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/adr.schema": "./src/schema/adr.schema.ts",
    "./schema/emit": "./src/schema/emit.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --outdir=dist --packages=external",
    "lint": "bun run typecheck",
    "schema:emit": "bun ./src/schema/emit.cli.ts",
    "typecheck": "tsc --noEmit --project ../../tsconfig.json"
  },
  "dependencies": {
    "yaml": "latest",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
